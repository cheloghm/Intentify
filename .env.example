# ============================================================
# INTENTIFY — UNIFIED ENVIRONMENT CONFIG EXAMPLE
# Copy this file to .env and fill in your values.
# .env is gitignored. This file IS committed.
# ============================================================

# --- ENVIRONMENT ---
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000

# --- PORTS (docker-compose) ---
FRONTEND_PORT=3000
BACKEND_PORT=5000
MONGO_PORT=27017
OPENSEARCH_PORT=9200

# --- FRONTEND ---
INTENTIFY_API_BASE_URL=http://localhost:5000

# --- MONGODB ---
Intentify__Mongo__ConnectionString=mongodb://localhost:27017
Intentify__Mongo__DatabaseName=intentify
Intentify__Mongo__UseTls=false

# --- JWT ---
Intentify__Jwt__Issuer=https://intentify.local
Intentify__Jwt__Audience=intentify-api
Intentify__Jwt__SigningKey=your-strong-jwt-signing-key-min-32-chars
Intentify__Jwt__AccessTokenMinutes=30

# --- CORS ---
Intentify__Cors__AllowedOrigins=http://localhost:3000,http://127.0.0.1:3000

# --- AI (Anthropic Claude via OpenAI-compatible endpoint) ---
Intentify__AI__ApiBaseUrl=https://api.anthropic.com/openai
Intentify__AI__ApiKey=your-anthropic-api-key
Intentify__AI__ChatModel=claude-sonnet-4-6
Intentify__AI__TimeoutSeconds=30
Intentify__AI__MaxPromptChars=12000

# --- OPENSEARCH ---
Intentify__OpenSearch__Enabled=true
Intentify__OpenSearch__Url=http://localhost:9200
Intentify__OpenSearch__IndexName=intentify-knowledge-chunks
Intentify__OpenSearch__Username=admin
Intentify__OpenSearch__Password=admin

# --- OPENSEARCH (docker-compose container settings) ---
OPENSEARCH_DISABLE_SECURITY_PLUGIN=true
OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m

# --- INTELLIGENCE (Google) ---
Intentify__Intelligence__Google__ApiKey=your-google-api-key
Intentify__Intelligence__Google__BaseUrl=https://www.googleapis.com
Intentify__Intelligence__Google__TimeoutSeconds=10
Intentify__Intelligence__Search__Provider=Google

# --- DEBUG ---
INTENTIFY_DEBUG_SECRET=your-debug-secret
