# Example environment variables for local development.
# Do not put secrets here. Copy to .env (which is gitignored) and fill values locally.

# Backend example
ASPNETCORE_ENVIRONMENT=Development
Intentify__AI__ApiKey=
Intentify__AI__ApiBaseUrl=
Intentify__AI__ChatModel=
Intentify__AI__EmbeddingModel=
Intentify__AI__TimeoutSeconds=30
Intentify__AI__MaxPromptChars=0

# Frontend example
NEXT_PUBLIC_API_BASE_URL=http://localhost:5100
