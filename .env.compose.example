# Copy to .env.compose for local Docker Compose runs. Do not commit real secrets.

# Public host ports
FRONTEND_PORT=3000
BACKEND_PORT=5000
MONGO_PORT=27017
OPENSEARCH_PORT=9200

# Frontend runtime API base (browser -> backend)
INTENTIFY_API_BASE_URL=http://localhost:5000

# Backend required settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
Intentify__Jwt__Issuer=intentify
Intentify__Jwt__Audience=intentify-users
Intentify__Jwt__SigningKey=replace-with-strong-local-secret
Intentify__Jwt__AccessTokenMinutes=30
Intentify__Cors__AllowedOrigins=http://localhost:3000
Intentify__Mongo__ConnectionString=mongodb://mongo:27017
Intentify__Mongo__DatabaseName=Intentify

# OpenSearch integration for testing
Intentify__OpenSearch__Enabled=true
Intentify__OpenSearch__Url=http://opensearch:9200
Intentify__OpenSearch__IndexName=intentify-knowledge-chunks
Intentify__OpenSearch__Username=admin
Intentify__OpenSearch__Password=admin
